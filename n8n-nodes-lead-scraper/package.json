{
  "name": "n8n-nodes-lead-scraper",
  "version": "1.0.0",
  "description": "n8n node for Lead Scraper — scrape business websites for emails, phones, and contact data",
  "keywords": ["n8n", "n8n-community-node-package", "lead-generation", "scraping", "crawl4ai"],
  "license": "MIT",
